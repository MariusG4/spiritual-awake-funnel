---
import LayoutOld from "../layouts/LayoutOld.astro";

const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---

<LayoutOld title="Success! Welcome Inside | Surviving Spiritual Stalking">
	<main class="thank-you-layout">
		<div class="container text-center glass-panel content-box">
			<div class="success-icon">✓</div>
			<h1 class="mb-4 text-gradient">Payment Successful!</h1>

			<p class="mb-6 desc-text">
				Welcome to the <strong>Surviving Spiritual Stalking</strong> community!
				Your access has been securely granted on Whop.
			</p>

			<div class="next-steps">
				<h3>Next Steps:</h3>
				<ol>
					<li>
						Check your email for the receipt and access link from
						Whop.
					</li>
					<li>
						Click the button below to go straight to your dashboard.
					</li>
					<li>Introduce yourself in the community lobby!</li>
				</ol>
			</div>

			<a href={WHOP_LINK} class="btn-primary mt-8">
				Access Your Purchase Now →
			</a>
		</div>
	</main>

	<!-- Conversion Tracking Push -->
	<script>
		document.addEventListener("DOMContentLoaded", () => {
			// Push to GTM / DataLayer
			window.dataLayer = window.dataLayer || [];
			window.dataLayer.push({
				event: "purchase",
				ecommerce: {
					currency: "USD",
					value: 97.0,
					items: [
						{
							item_name: "Surviving Spiritual Stalking",
							price: 97.0,
							quantity: 1,
						},
					],
				},
			});

			// Push to Meta Pixel if available
			if (typeof fbq === "function") {
				fbq("track", "Purchase", { currency: "USD", value: 97.0 });
			}
		});
	</script>
</LayoutOld>

<style>
	.thank-you-layout {
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 4rem 0;
	}

	.content-box {
		max-width: 650px;
		margin: 0 auto;
		padding: 4rem 2rem;
		border-top: 4px solid #10b981; /* Success Green */
	}

	.success-icon {
		width: 80px;
		height: 80px;
		background: #10b981;
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3rem;
		font-weight: bold;
		margin: 0 auto 2rem;
		box-shadow: 0 0 30px rgba(16, 185, 129, 0.4);
	}

	.text-gradient {
		background: linear-gradient(135deg, #10b981, #34d399);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.desc-text {
		color: var(--text-muted);
		font-size: 1.25rem;
	}

	.next-steps {
		background: rgba(15, 23, 42, 0.5);
		padding: 2rem;
		border-radius: 12px;
		text-align: left;
		margin-top: 2rem;
	}

	.next-steps h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
		color: #e2e8f0;
	}

	.next-steps ol {
		padding-left: 1.5rem;
		color: var(--text-muted);
	}

	.next-steps li {
		margin-bottom: 0.75rem;
		line-height: 1.6;
	}
</style>
