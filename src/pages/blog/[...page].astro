---
import LayoutOld from "../../layouts/LayoutOld.astro";
import { getCollection } from "astro:content";
import { resolveImage } from "../../lib/cloudinary";

// Generate paginated routes — 6 posts per page
export async function getStaticPaths({ paginate }) {
    const allPosts = await getCollection("blog");
    const posts = allPosts.filter((post) => post.data.pubDate <= new Date());
    posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return paginate(posts, { pageSize: 6 });
}

const { page } = Astro.props;
const isPageOne = page.currentPage === 1;

const title = isPageOne
    ? "Blog | Spiritual Shield System"
    : `Blog — Page ${page.currentPage} | Spiritual Shield System`;

const description =
    "Read the latest articles on spiritual thinking and protection.";

// Self-referencing canonical for each paginated page
const canonicalUrl = isPageOne
    ? `${Astro.site}blog/`
    : `${Astro.site}blog/${page.currentPage}/`;
---

<LayoutOld title={title} description={description}>
    {/* Self-referencing canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* Pagination hints for crawlers (Bing, Yandex, AI bots) */}
    {page.url.prev && <link rel="prev" href={page.url.prev} />}
    {page.url.next && <link rel="next" href={page.url.next} />}

    <main class="container mt-12 mb-12" style="min-height: 80vh;">
        <header class="text-center mb-12">
            <h1 class="highlight-text mb-4">Our Blog</h1>
            <p
                style="color: var(--text-muted); font-size: 1.2rem; max-width: 600px; margin: 0 auto;"
            >
                Insights, practices, and guides on maintaining a strong
                spiritual shield.
            </p>
        </header>

        <div class="blog-grid">
            {
                page.data.map((post) => {
                    const cardImage = resolveImage(
                        post.data.cloudinaryId,
                        post.data.image,
                        [300, 600, 900],
                        {
                            crop: "fill",
                            gravity: "auto",
                            quality: "auto",
                            format: "auto",
                        },
                    );
                    return (
                        <article class="glass-panel blog-card">
                            <a href={`/blog/${post.id}`}>
                                {cardImage.src && (
                                    <div class="blog-image-wrapper mb-4">
                                        <img
                                            src={cardImage.src}
                                            srcset={cardImage.srcset}
                                            sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
                                            alt={
                                                post.data.imageAlt ||
                                                post.data.title
                                            }
                                            class="blog-image"
                                            loading="lazy"
                                            decoding="async"
                                            width="600"
                                            height="338"
                                        />
                                    </div>
                                )}
                                <span class="category-badge">
                                    {post.data.category}
                                </span>
                                <div class="blog-meta mb-2">
                                    <time
                                        datetime={post.data.pubDate.toISOString()}
                                    >
                                        {post.data.pubDate.toLocaleDateString(
                                            "en-US",
                                            {
                                                year: "numeric",
                                                month: "long",
                                                day: "numeric",
                                            },
                                        )}
                                    </time>
                                    {post.data.author && (
                                        <span> • {post.data.author}</span>
                                    )}
                                </div>
                                <h2 class="blog-title mb-2">
                                    {post.data.title}
                                </h2>
                                <p class="blog-excerpt">
                                    {post.data.description}
                                </p>
                            </a>
                        </article>
                    );
                })
            }
        </div>

        {/* Pagination Controls */}
        {
            page.lastPage > 1 && (
                <nav class="pagination" aria-label="Blog pagination">
                    {page.url.prev && (
                        <a
                            href={page.url.prev}
                            class="pagination-link pagination-prev"
                        >
                            ← Newer Posts
                        </a>
                    )}
                    <div class="pagination-numbers">
                        {Array.from(
                            { length: page.lastPage },
                            (_, i) => i + 1,
                        ).map((pageNum) =>
                            pageNum === page.currentPage ? (
                                <span
                                    class="pagination-number pagination-active"
                                    aria-current="page"
                                >
                                    {pageNum}
                                </span>
                            ) : (
                                <a
                                    href={
                                        pageNum === 1
                                            ? "/blog/"
                                            : `/blog/${pageNum}/`
                                    }
                                    class="pagination-number"
                                >
                                    {pageNum}
                                </a>
                            ),
                        )}
                    </div>
                    {page.url.next && (
                        <a
                            href={page.url.next}
                            class="pagination-link pagination-next"
                        >
                            Older Posts →
                        </a>
                    )}
                </nav>
            )
        }
    </main>
</LayoutOld>

<style>
    .blog-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }
    .blog-card {
        padding: 1.5rem;
        transition:
            transform var(--transition-smooth),
            box-shadow var(--transition-smooth);
        border: 1px solid var(--glass-border);
    }
    .blog-card:hover {
        transform: translateY(-5px);
        border-color: rgba(var(--primary-rgb), 0.4);
        box-shadow: 0 10px 40px rgba(var(--primary-rgb), 0.2);
    }
    .blog-image-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.5);
    }
    .blog-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .blog-card:hover .blog-image {
        transform: scale(1.05);
    }
    .blog-meta {
        font-size: 0.9rem;
        color: var(--text-muted);
    }
    .category-badge {
        display: inline-block;
        background: rgba(var(--accent-rgb), 0.15);
        border: 1px solid rgba(var(--accent-rgb), 0.4);
        color: var(--accent);
        border-radius: 0.375rem;
        padding: 0.2rem 0.65rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        line-height: 1.4;
        margin-bottom: 0.5rem;
    }
    .blog-title {
        font-size: 1.5rem;
        color: var(--text-main);
        transition: color var(--transition-fast);
    }
    .blog-card:hover .blog-title {
        color: var(--primary);
    }
    .blog-excerpt {
        color: var(--text-muted);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Pagination Styles */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        margin-top: 3rem;
        flex-wrap: wrap;
    }
    .pagination-link {
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        background: rgba(var(--primary-rgb), 0.1);
        border: 1px solid rgba(var(--primary-rgb), 0.3);
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        transition: all var(--transition-fast);
    }
    .pagination-link:hover {
        background: rgba(var(--primary-rgb), 0.2);
        border-color: rgba(var(--primary-rgb), 0.5);
        transform: translateY(-2px);
    }
    .pagination-numbers {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }
    .pagination-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 8px;
        background: rgba(var(--primary-rgb), 0.05);
        border: 1px solid rgba(var(--primary-rgb), 0.2);
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: all var(--transition-fast);
    }
    .pagination-number:hover {
        background: rgba(var(--primary-rgb), 0.15);
        border-color: rgba(var(--primary-rgb), 0.4);
        color: var(--text-main);
    }
    .pagination-active {
        background: rgba(var(--primary-rgb), 0.25);
        border-color: var(--primary);
        color: var(--primary);
        font-weight: 700;
        cursor: default;
    }
</style>
