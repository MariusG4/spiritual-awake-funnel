---
import LayoutOld from '../layouts/LayoutOld.astro';
import HeroOld from '../components/HeroOld.astro';
import VSLOld from '../components/VSLOld.astro';
import BenefitsOld from '../components/BenefitsOld.astro';
import TestimonialsOld from '../components/TestimonialsOld.astro';
import FAQOld from '../components/FAQOld.astro';
import OfferBoxOld from '../components/OfferBoxOld.astro';
import LeadPopupOld from '../components/LeadPopupOld.astro';

const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---

<LayoutOld title="Surviving Spiritual Stalking | Shield Your Energy" videoSchema={true}>
	<main>
		<HeroOld />
		<VSLOld />
		
		<!-- Quick Divider -->
		<div class="divider"></div>
		
		<div class="container text-center py-12">
			<h2 class="section-title">Who is this for?</h2>
			<p class="section-desc">If you constantly feel drained, watched, or energetically attacked by unseen forces, toxic individuals, or narcissistic patterns—this is your absolute shield.</p>
		</div>

		<BenefitsOld />
		<TestimonialsOld />
		<FAQOld />
		<OfferBoxOld />

		<!-- Exit Intent Popup (Hidden by default) -->
		<div id="exit-popup" class="popup-overlay" style="display: none;">
			<div class="popup-content glass-panel">
				<button id="close-popup" class="close-btn">&times;</button>
				<h3>Wait! Before You Go...</h3>
				<p>Don't leave yourself unprotected. Get <strong>Instant Access</strong> to the support group and shielding frameworks today.</p>
				<a href={WHOP_LINK} class="btn-primary w-full mt-4" style="margin-top: 1.5rem;">
					Yes, Protect My Energy Now
				</a>
			</div>
		</div>

		<!-- New Lead Capture Overlay -->
		<LeadPopupOld whopLink={WHOP_LINK} />
	</main>

	<!-- Exit Popup Script -->
	<script>
		document.addEventListener("mouseleave", (e) => {
			if (e.clientY < 0) {
				const popup = document.getElementById("exit-popup");
				// Only show once per session
				if (popup && !sessionStorage.getItem("popup_shown")) {
					popup.style.display = "flex";
					sessionStorage.setItem("popup_shown", "true");
					
					// Track exit intent event
					(window as any).dataLayer = (window as any).dataLayer || [];
					(window as any).dataLayer.push({ 'event': 'exit_intent_popup_shown' });
				}
			}
		});

		document.getElementById("close-popup")?.addEventListener("click", () => {
			const popup = document.getElementById("exit-popup");
			if (popup) popup.style.display = "none";
		});

		// Close if clicked outside
		document.getElementById("exit-popup")?.addEventListener("click", (e) => {
			if (e.target === document.getElementById("exit-popup")) {
				document.getElementById("exit-popup")!.style.display = "none";
			}
		});
	</script>
</LayoutOld>

<style>
	.py-12 { padding: 4rem 0; }
	.section-title { font-size: clamp(2rem, 6vw, 2.5rem); margin-bottom: 1rem; }
	.section-desc { font-size: clamp(1.1rem, 4vw, 1.25rem); color: var(--text-muted); max-width: 700px; margin: 0 auto; line-height: 1.6; padding: 0 1rem; }
	.divider { height: 1px; width: 100%; background: linear-gradient(90deg, transparent, rgba(var(--primary-rgb),0.5), transparent); margin: 2rem 0; }

	/* Popup Styles */
	.popup-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(8px);
		z-index: 9999;
		justify-content: center;
		align-items: center;
		animation: fadeIn 0.3s ease;
	}

	.popup-content {
		max-width: 500px;
		width: 90%;
		text-align: center;
		position: relative;
		padding: 3rem 2rem;
	}

	.close-btn {
		position: absolute;
		top: 15px;
		right: 20px;
		background: none;
		border: none;
		color: var(--text-muted);
		font-size: 2rem;
		cursor: pointer;
		transition: color var(--transition-fast);
	}

	.close-btn:hover {
		color: white;
	}

	.popup-content h3 {
		font-size: 2rem;
		margin-bottom: 1rem;
		color: var(--primary);
	}

	.popup-content p {
		font-size: 1.1rem;
		color: var(--text-main);
		margin-bottom: 1rem;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
</style>
