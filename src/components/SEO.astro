---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: "website" | "article";
  // Article-specific
  author?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  faq?: FaqItem[];
  /**
   * Set to true ONLY on pages that actually embed the shielding video (i.e. the homepage).
   * When false (default), the VideoObject JSON-LD schema is omitted, preventing the
   * "Video not on watch page" warning in Google Search Console.
   */
  videoSchema?: boolean;
  /**
   * Set to true ONLY on the homepage. Emits the Product schema with reviews and ratings.
   * Keeping it scoped prevents incorrect rich-result eligibility on blog/index pages.
   */
  productSchema?: boolean;
}

const {
  title,
  description = "Stop Unwanted Spiritual Intrusion Before It Escalates",
  image = "/og-image.jpg",
  canonicalUrl = Astro.url.href,
  type = "website",
  author,
  pubDate,
  updatedDate,
  tags = [],
  faq = [],
  videoSchema = false,
  productSchema = false,
} = Astro.props;

const isArticle = type === "article";

// Build an absolute OG image URL.
// Guards against three edge cases:
//   1. `image` is already absolute (Cloudinary URL) → use it as-is.
//   2. `image` is a root-relative path like "/og-image.jpg" → resolve against origin.
//   3. `image` is empty string (getCloudinaryUrl returned '' because CLOUD_NAME is unset
//      and the caller used it without checking) → fall back to "/og-image.jpg" first,
//      otherwise new URL('', Astro.url) would silently return the current page URL.
const _safeImage = image || '/og-image.jpg';
const absImage = _safeImage.startsWith('http')
  ? _safeImage
  : new URL(_safeImage, Astro.url).href;

// --- JSON-LD schemas ---
const SITE_URL = "https://spiritualshieldsystem.com";
const schemas: object[] = [
  // Organization — defines the site entity for Google's Knowledge Graph
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: "Shield Your Energy",
    alternateName: "Spiritual Shield System",
    url: SITE_URL,
    description:
      "The authoritative resource for spiritual protection against psychic intrusion and energetic attacks. We provide practical shielding frameworks for individuals experiencing spiritual stalking, narcissistic energy vampires, and unwanted spiritual attachments.",
    logo: {
      "@type": "ImageObject",
      url: `${SITE_URL}/android-chrome-512x512.png`,
      width: 512,
      height: 512,
    },
    sameAs: [
      "https://whop.com/escapenazis/surviving-spiritual-stalking",
    ],
  },
  // WebSite — enables sitelinks search box eligibility in Google SERPs
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: "Shield Your Energy",
    url: SITE_URL,
    description:
      "Practical spiritual protection frameworks against psychic intrusion, energetic attacks, and spiritual stalking.",
    inLanguage: "en-US",
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
];

// Article/BlogPosting schema
if (isArticle) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description: description,
    image: absImage,
    url: canonicalUrl,
    inLanguage: "en-US",
    author: {
      "@type": "Person",
      name: author || "Spiritual Shield System",
    },
    publisher: {
      "@type": "Organization",
      name: "Shield Your Energy",
      url: "https://spiritualshieldsystem.com",
    },
    ...(pubDate && { datePublished: pubDate.toISOString() }),
    // dateModified falls back to pubDate so every article always has this field
    ...((updatedDate || pubDate) && { dateModified: (updatedDate ?? pubDate)!.toISOString() }),
    ...(tags.length > 0 && { keywords: tags.join(", ") }),
  });

  // BreadcrumbList
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", Astro.url).toString(),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: new URL("/blog", Astro.url).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: title,
        item: canonicalUrl,
      },
    ],
  });

  // FAQPage schema
  if (faq.length > 0) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    });
  }
} else {
  // Generic WebPage
  schemas.push({
    "@context": "https://schema.org",
    "@type": "WebPage",
    url: canonicalUrl,
    name: title,
    inLanguage: "en-US",
    description: description,
  });

  // Product schema — scoped to the homepage only via the `productSchema` prop
  if (productSchema) schemas.push({
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Surviving Spiritual Stalking – Shield Your Energy Access",
    brand: {
      "@type": "Organization",
      name: "Shield Your Energy",
    },
    description:
      "Exclusive group access featuring shielding techniques to protect you from spiritual intrusion and energetic attacks. Limited spots available.",
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "4.9",
      reviewCount: "2",
    },
    review: [
      {
        "@type": "Review",
        author: { "@type": "Person", name: "Sarah M." },
        reviewBody:
          "Before this, I felt constantly drained. I thought I was just burnt out. After applying the shielding techniques from module 2, the heavy feeling lifted overnight. It's like I finally have my life back.",
        reviewRating: { "@type": "Rating", ratingValue: "5" },
        datePublished: "2023-12-01",
      },
      {
        "@type": "Review",
        author: { "@type": "Person", name: "Verified Member" },
        reviewBody:
          "The community alone is worth 10x the price. Being around others who actually understand what spiritual stalking feels like...",
        reviewRating: { "@type": "Rating", ratingValue: "5" },
        datePublished: "2024-01-15",
      },
    ],
  });

  // VideoObject schema — only on the page that actually embeds the video.
  // Placing this on any other page causes a "Video not on watch page" warning
  // in Google Search Console because Google verifies the video is present in the HTML.
  if (videoSchema) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      name: "2-Minute Shielding Video",
      description:
        "A brief 2-minute video offering vital shielding techniques before spiritual intrusion escalates.",
      // `url` tells Google which page is the canonical watch page for this video.
      // Without it Google falls back to whatever page the JSON-LD was found on.
      url: "https://spiritualshieldsystem.com/",
      uploadDate: "2024-03-11T00:00:00Z",
      duration: "PT2M",
      embedUrl:
        "https://www.youtube-nocookie.com/embed/mqyGwE5VcUM?rel=0&modestbranding=1",
      // contentUrl is the direct watch URL Google can verify independently.
      contentUrl: "https://www.youtube.com/watch?v=mqyGwE5VcUM",
      thumbnailUrl: "https://i.ytimg.com/vi/mqyGwE5VcUM/maxresdefault.jpg",
      publisher: {
        "@type": "Organization",
        name: "Shield Your Energy",
        url: "https://spiritualshieldsystem.com",
      },
    });
  }
}
---

<!-- SEO Meta Tags -->
<meta name="description" content={description} />
<meta name="theme-color" content="#6d28d9" />
<link rel="canonical" href={canonicalUrl} />
{tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Shield Your Energy" />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={absImage} />
<meta property="og:image:alt" content={description} />

<!-- Article-specific Open Graph tags -->
{isArticle && author && <meta property="article:author" content={author} />}
{
  isArticle && pubDate && (
    <meta property="article:published_time" content={pubDate.toISOString()} />
  )
}
{
  /* modified_time falls back to pubDate — every published article should have this tag */
  isArticle && (updatedDate || pubDate) && (
    <meta
      property="article:modified_time"
      content={(updatedDate ?? pubDate)!.toISOString()}
    />
  )
}
{isArticle && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@ShieldYourEnergy" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absImage} />
<meta name="twitter:image:alt" content={description} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(schemas)} />
