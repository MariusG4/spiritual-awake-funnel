---
import { Image } from 'astro:assets';
const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---
<section class="hero-section">
  <div class="container hero-grid">
    <div class="hero-content">
      <div class="badge">⚠️ URGENT: If You're Experiencing These Symptoms</div>
      
      <!-- A/B Tested Headline Wrapper -->
      <h1 id="hero-headline" class="headline">
        They're Using <br/> <span class="highlight-text">Spiritual Warfare</span> <br/> Against You
      </h1>
      
      <p class="subheadline">
        If you've crossed paths with drug dealers, occultists, masons, or other dangerous people... and now you're experiencing intrusive thoughts, night sweats, and behavioral changes you can't explain—<strong class="highlight-text">you're not going crazy.</strong>
      </p>

      <div class="cta-wrapper">
        <a href={WHOP_LINK} class="btn-primary btn-pulse cta-button">
          Get Instant Access Now
        </a>
        <p class="guarantee">🔒 Secure checkout via Whop. Instant access.</p>
      </div>
      
      <div class="social-proof">
        <div class="avatars">
          <!-- Placeholder avatars -->
          <div class="avatar" style="background-image: url('https://randomuser.me/api/portraits/women/44.jpg')"></div>
          <div class="avatar" style="background-image: url('https://randomuser.me/api/portraits/men/32.jpg')"></div>
          <div class="avatar" style="background-image: url('https://randomuser.me/api/portraits/women/68.jpg')"></div>
          <div class="avatar" style="background-image: url('https://randomuser.me/api/portraits/men/46.jpg')"></div>
          <div class="avatar" style="background-image: url('https://randomuser.me/api/portraits/women/90.jpg')"></div>
        </div>
        <div class="proof-text">
          <div class="stars">⭐⭐⭐⭐⭐</div>
          <span>Rated 4.9/5 by our community</span>
        </div>
      </div>
    </div>
    
    <div class="hero-image glass-panel">
      <Image src="/img/3d-book-mockup.png" alt="Surviving Spiritual Stalking 3D Book Mockup" width={600} height={800} class="mockup-image" />
    </div>
  </div>
</section>

<script>
  // A/B Testing specific logic for headline
  document.addEventListener('ab_variant_loaded', (e: any) => {
    const variant = e.detail?.variant;
    const headlineEl = document.getElementById('hero-headline');
    
    if (headlineEl && variant === 'B') {
      headlineEl.innerHTML = `You're Not Crazy. <br/> <span class="highlight-text">You're Being Spiritually Stalked.</span>`;
    }
  });
</script>

<style>
  .hero-section {
    padding: 6rem 0 4rem;
    position: relative;
    overflow: hidden;
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }
  
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    background: rgba(236, 72, 153, 0.2);
    color: #fbcfe8;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(236, 72, 153, 0.4);
  }

  .headline {
    font-size: clamp(2.25rem, 8vw, 4rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .subheadline {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 90%;
  }

  .cta-wrapper {
    width: 100%;
    margin-bottom: 3rem;
  }

  .cta-button {
    width: 100%;
    max-width: 400px;
  }

  .guarantee {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .avatars {
    display: flex;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-size: cover;
    border: 3px solid var(--bg-dark);
    margin-left: -15px;
  }
  .avatar:first-child { margin-left: 0; }

  .stars {
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-bottom: 0.2rem;
  }

  .proof-text span {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.8);
  }

  /* Mockup Book CSS Art */
  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.4), rgba(15, 23, 42, 0.6));
    border: 1px solid rgba(139, 92, 246, 0.3);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 20px rgba(139, 92, 246, 0.2);
  }

  .mockup-image {
    width: 100%;
    max-width: 320px;
    height: auto;
    object-fit: contain;
    animation: float 6s ease-in-out infinite;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.4));
  }

  @keyframes float {
    0% { transform: rotateY(-15deg) rotateX(5deg) translateY(0px); }
    50% { transform: rotateY(-10deg) rotateX(10deg) translateY(-20px); }
    100% { transform: rotateY(-15deg) rotateX(5deg) translateY(0px); }
  }

  @media (max-width: 992px) {
    .hero-section { padding: 3rem 0 2rem; } /* Less top padding on mobile */
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem; /* Tighter gap */
    }
    .hero-content {
      align-items: center;
    }
    .subheadline { max-width: 100%; } /* Max width relax for centering */
    .avatars { justify-content: center; }
    .social-proof { flex-direction: column; gap: 0.5rem; }
    
    .mockup-image {
      max-width: 240px;
    }
    .hero-image { min-height: 350px; }
  }

  @media (max-width: 480px) {
    .badge { font-size: 0.8rem; padding: 0.4rem 0.8rem; }
    .hero-section { padding: 2rem 0; }
  }
</style>
