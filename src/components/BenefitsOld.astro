---
---
<section class="benefits-section">
  <div class="container container-sm">
    <div class="text-center mb-12">
      <h2>Are You Experiencing These Symptoms?</h2>
      <p class="section-desc">If you have more than 2, they may already have a connection to you.</p>
    </div>

    <div class="benefits-list">
      
      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">🧠</div>
        <div>
          <h3>Intrusive Thoughts</h3>
          <p>Thoughts that won't leave, looping constantly</p>
        </div>
      </div>

      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">😰</div>
        <div>
          <h3>Night Sweats</h3>
          <p>Waking up drenched despite cool room</p>
        </div>
      </div>

      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">👁️</div>
        <div>
          <h3>Feeling Watched</h3>
          <p>Constant sense of being observed</p>
        </div>
      </div>

      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">🌙</div>
        <div>
          <h3>Sleep Disruption</h3>
          <p>Waking at 2-3 AM repeatedly</p>
        </div>
      </div>

      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">😱</div>
        <div>
          <h3>Strange Dreams</h3>
          <p>Vivid, disturbing dreams that feel real</p>
        </div>
      </div>

      <div class="benefit-item glass-panel">
        <div class="icon" style="font-size: 2.5rem;">🎭</div>
        <div>
          <h3>Loss of Control</h3>
          <p>Feeling like something external influences you</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .benefits-section {
    padding: 6rem 0;
    position: relative;
  }

  .container-sm {
    max-width: 800px;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .section-desc {
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  .benefits-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .benefit-item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2.5rem;
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .benefit-item:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
  }

  .icon {
    font-size: 2.5rem;
    background: rgba(139, 92, 246, 0.2);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    flex-shrink: 0;
  }

  h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    color: #e2e8f0;
  }

  p {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .benefits-list { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .benefits-section { padding: 4rem 0; }
  }

  @media (max-width: 600px) {
    .benefit-item { flex-direction: column; gap: 1.25rem; padding: 1.5rem; }
    .benefit-item:hover { transform: translateY(-5px); }
    .icon { width: 50px; height: 50px; font-size: 2rem; }
    h3 { font-size: 1.2rem; }
  }
</style>
