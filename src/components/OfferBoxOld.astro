---
const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---

<section class="offer-section">
  <div class="container">
    <div class="offer-box glass-panel text-center">
      <h2>Get The Complete Survival Guide Now</h2>
      <p class="subtitle">
        Everything you need to recognize, escape, and protect yourself from
        spiritual harassment—delivered instantly.
      </p>

      <div class="price-stack" style="position: relative;">
        <!-- Scarcity Badge -->
        <div
          id="scarcity-badge-old"
          class="scarcity-badge-old"
          style="position: absolute; top: -15px; right: -15px; background: #ea580c; color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; transform: scale(0.95); opacity: 0; transition: all 0.5s;"
        >
          🔥 <span id="spots-text-old">Loading...</span>
        </div>
        <span class="msrp">Total Value: <s>$413+</s></span>
        <span class="sale-price">Today: $43</span>
      </div>

      <ul class="offer-list detailed-offer-list">
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Complete Survival Guide</span
            >
            <span class="item-badge">Core</span>
          </div>
          <span class="item-price">$47</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Protection Protocols</span
            >
            <span class="item-badge">Core</span>
          </div>
          <span class="item-price">$27</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Full Video Course</span
            >
            <span class="item-badge">Core</span>
          </div>
          <span class="item-price">$97</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Understanding the Attack Presentation</span
            >
            <span class="item-badge">Core</span>
          </div>
          <span class="item-price">$37</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> 1-on-1 Private Call (15 min)</span
            >
            <span class="item-badge bonus">Bonus #1</span>
          </div>
          <span class="item-price">$97</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Emotion & Thought Tracker</span
            >
            <span class="item-badge bonus">Bonus #2</span>
          </div>
          <span class="item-price">$17</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Mapping Your Situation Worksheet</span
            >
            <span class="item-badge bonus">Bonus #3</span>
          </div>
          <span class="item-price">$17</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Focus Exercises</span
            >
            <span class="item-badge bonus">Bonus #4</span>
          </div>
          <span class="item-price">$27</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Private Community (Lifetime)</span
            >
            <span class="item-badge bonus">Bonus #5</span>
          </div>
          <span class="item-price">$47</span>
        </li>
        <li>
          <div class="item-text">
            <span class="item-title"
              ><span class="check">✓</span> Future Product Discounts</span
            >
            <span class="item-badge bonus">Bonus #6</span>
          </div>
          <span class="item-price priceless">Priceless</span>
        </li>
      </ul>

      <a href={WHOP_LINK} class="btn-primary w-full pulse-btn"
        >🔓 GET INSTANT ACCESS →</a
      >

      <div class="secure-checkout">
        <p>🔒 100% Confidential • No One Will Know You Have This</p>
      </div>
    </div>
  </div>
</section>

<style>
  .offer-section {
    padding: 6rem 0;
  }

  .offer-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 4rem;
    border: 1px solid rgba(139, 92, 246, 0.4);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);
  }

  h2 {
    font-size: clamp(2rem, 5vw, 2.5rem);
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: clamp(1.05rem, 3vw, 1.15rem);
    margin-bottom: 2rem;
  }

  .price-stack {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    background: rgba(0, 0, 0, 0.2);
    padding: 2rem;
    border-radius: 12px;
  }

  .msrp {
    color: var(--text-muted);
    font-size: 1.25rem;
  }

  .sale-price {
    color: var(--primary);
    font-size: clamp(3rem, 10vw, 4rem);
    font-weight: 800;
    font-family: "Outfit", sans-serif;
    line-height: 1;
    margin-top: 0.5rem;
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
  }

  .offer-list {
    list-style: none;
    text-align: left;
    margin: 0 auto 3rem;
    max-width: 450px;
  }

  .detailed-offer-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
    padding: 0.75rem 0;
    margin-bottom: 0;
    font-size: clamp(0.95rem, 3vw, 1.05rem);
  }

  .detailed-offer-list li:last-child {
    border-bottom: none;
  }

  .item-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .item-title {
    color: white;
    font-weight: 500;
    display: flex;
    align-items: flex-start;
  }

  .item-badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-left: 1.75rem;
    margin-top: 0.25rem;
  }

  .item-badge.bonus {
    color: #ea580c;
    font-weight: bold;
  }

  .item-price {
    font-weight: 600;
    color: white;
    margin-left: 1rem;
  }

  .item-price.priceless {
    color: #10b981;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .check {
    color: #10b981; /* Emerald green check */
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .w-full {
    width: 100%;
    display: block;
    text-align: center;
  }

  .pulse-btn {
    animation: pulse 2s infinite;
  }

  .secure-checkout {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7);
    }
    70% {
      box-shadow: 0 0 0 20px rgba(139, 92, 246, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(139, 92, 246, 0);
    }
  }

  @media (max-width: 768px) {
    .offer-box {
      padding: 2.5rem 1.5rem;
    }
    .offer-section {
      padding: 4rem 0;
    }
  }

  @media (max-width: 480px) {
    .offer-box {
      padding: 2rem 1rem;
    }
  }
</style>

<script>
  import { supabase } from "../lib/supabase";

  const initScarcityBadge = async () => {
    try {
      const { data, error } = await supabase
        .from("scarcity")
        .select("spots_remaining, total_spots")
        .single();

      if (error) throw error;

      const badge = document.getElementById("scarcity-badge-old");
      const text = document.getElementById("spots-text-old");

      if (text && badge) {
        text.innerText = `Only ${data.spots_remaining} Spots Left!`;
        badge.style.transform = "scale(1)";
        badge.style.opacity = "1";

        // Add a little shake animation to draw attention
        setTimeout(() => {
          badge.classList.add("pulse-btn");
        }, 500);
      }
    } catch (err) {
      console.error("OfferBoxOld Scarcity Error:", err);
      // Hide badge gracefully if fetch fails
      const badge = document.getElementById("scarcity-badge-old");
      if (badge) badge.style.display = "none";
    }
  };

  initScarcityBadge();
</script>
