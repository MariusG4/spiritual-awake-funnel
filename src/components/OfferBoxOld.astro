---
const WHOP_LINK = "https://whop.com/escapenazis";
---
<section class="offer-section">
  <div class="container">
    <div class="offer-box glass-panel text-center">
      <h2>Secure Your Access Now</h2>
      <p class="subtitle">Join the exclusive community and get instant access to the full protocol.</p>
      
      <div class="price-stack">
        <span class="msrp">Normal Value: <s>$497</s></span>
        <span class="sale-price">Today: $97</span>
      </div>

      <ul class="offer-list">
        <li><span class="check">✓</span> Full "Surviving Spiritual Stalking" System</li>
        <li><span class="check">✓</span> Private Community Access (Whop)</li>
        <li><span class="check">✓</span> Weekly Live QA & Support</li>
        <li><span class="check">✓</span> Bonus: Advanced Shielding Techniques</li>
      </ul>

      <a href={WHOP_LINK} class="btn-primary w-full pulse-btn">Join Now & Save</a>

      <div class="secure-checkout">
        <p>🔒 256-Bit SSL Secure Checkout on Whop</p>
      </div>
    </div>
  </div>
</section>

<style>
  .offer-section {
    padding: 6rem 0;
  }

  .offer-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 4rem;
    border: 1px solid rgba(139, 92, 246, 0.4);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);
  }

  h2 {
    font-size: clamp(2rem, 5vw, 2.5rem);
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: clamp(1.05rem, 3vw, 1.15rem);
    margin-bottom: 2rem;
  }

  .price-stack {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    background: rgba(0,0,0,0.2);
    padding: 2rem;
    border-radius: 12px;
  }

  .msrp {
    color: var(--text-muted);
    font-size: 1.25rem;
  }

  .sale-price {
    color: var(--primary);
    font-size: clamp(3rem, 10vw, 4rem);
    font-weight: 800;
    font-family: 'Outfit', sans-serif;
    line-height: 1;
    margin-top: 0.5rem;
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
  }

  .offer-list {
    list-style: none;
    text-align: left;
    margin: 0 auto 3rem;
    max-width: 350px;
  }

  .offer-list li {
    font-size: clamp(1rem, 3vw, 1.1rem);
    margin-bottom: 1rem;
    color: var(--text-main);
    display: flex;
    align-items: flex-start;
  }

  .check {
    color: #10b981; /* Emerald green check */
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .w-full { width: 100%; display: block; text-align: center; }

  .pulse-btn {
    animation: pulse 2s infinite;
  }

  .secure-checkout {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7); }
    70% { box-shadow: 0 0 0 20px rgba(139, 92, 246, 0); }
    100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0); }
  }

  @media (max-width: 768px) {
    .offer-box { padding: 2.5rem 1.5rem; }
    .offer-section { padding: 4rem 0; }
  }

  @media (max-width: 480px) {
    .offer-box { padding: 2rem 1rem; }
  }
</style>
