---
const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---
<section class="offer-section">
  <div class="container">
    <div class="offer-box glass-panel text-center">
      <h2>Get The Complete Survival Guide Now</h2>
      <p class="subtitle">Everything you need to recognize, escape, and protect yourself from spiritual harassment—delivered instantly.</p>
      
      <div class="price-stack" style="position: relative;">
        <!-- Scarcity Badge -->
        <div id="scarcity-badge-old" class="scarcity-badge-old" style="position: absolute; top: -15px; right: -15px; background: #ea580c; color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; transform: scale(0.95); opacity: 0; transition: all 0.5s;">
          🔥 <span id="spots-text-old">Loading...</span>
        </div>
        <span class="msrp">Normal Value: <s>$197</s></span>
        <span class="sale-price">Today: $27</span>
      </div>

      <ul class="offer-list">
        <li><span class="check">✓</span> Complete Survival Guide & Protection Protocols</li>
        <li><span class="check">✓</span> Electronics Safety & Escape Strategy</li>
        <li><span class="check">✓</span> Mental Fortification Techniques</li>
        <li><span class="check">✓</span> Instant Action Plan (Next 24 Hours)</li>
      </ul>

      <a href={WHOP_LINK} class="btn-primary w-full pulse-btn">🔓 GET INSTANT ACCESS →</a>

      <div class="secure-checkout">
        <p>🔒 100% Confidential • No One Will Know You Have This</p>
      </div>
    </div>
  </div>
</section>

<style>
  .offer-section {
    padding: 6rem 0;
  }

  .offer-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 4rem;
    border: 1px solid rgba(139, 92, 246, 0.4);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);
  }

  h2 {
    font-size: clamp(2rem, 5vw, 2.5rem);
    margin-bottom: 1rem;
    color: white;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: clamp(1.05rem, 3vw, 1.15rem);
    margin-bottom: 2rem;
  }

  .price-stack {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    background: rgba(0,0,0,0.2);
    padding: 2rem;
    border-radius: 12px;
  }

  .msrp {
    color: var(--text-muted);
    font-size: 1.25rem;
  }

  .sale-price {
    color: var(--primary);
    font-size: clamp(3rem, 10vw, 4rem);
    font-weight: 800;
    font-family: 'Outfit', sans-serif;
    line-height: 1;
    margin-top: 0.5rem;
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
  }

  .offer-list {
    list-style: none;
    text-align: left;
    margin: 0 auto 3rem;
    max-width: 350px;
  }

  .offer-list li {
    font-size: clamp(1rem, 3vw, 1.1rem);
    margin-bottom: 1rem;
    color: var(--text-main);
    display: flex;
    align-items: flex-start;
  }

  .check {
    color: #10b981; /* Emerald green check */
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .w-full { width: 100%; display: block; text-align: center; }

  .pulse-btn {
    animation: pulse 2s infinite;
  }

  .secure-checkout {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7); }
    70% { box-shadow: 0 0 0 20px rgba(139, 92, 246, 0); }
    100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0); }
  }

  @media (max-width: 768px) {
    .offer-box { padding: 2.5rem 1.5rem; }
    .offer-section { padding: 4rem 0; }
  }

  @media (max-width: 480px) {
    .offer-box { padding: 2rem 1rem; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const { supabase } = await import("../lib/supabase");
      const { data, error } = await supabase
        .from('scarcity')
        .select('spots_remaining, total_spots')
        .single();
        
      if (error) throw error;
      
      const badge = document.getElementById("scarcity-badge-old");
      const text = document.getElementById("spots-text-old");
      
      if (text && badge) {
        text.innerText = `Only ${data.spots_remaining} Spots Left!`;
        badge.style.transform = "scale(1)";
        badge.style.opacity = "1";
        
        // Add a little shake animation to draw attention
        setTimeout(() => {
          badge.classList.add("pulse-btn");
        }, 500);
      }
    } catch(err) {
      console.error("OfferBoxOld Scarcity Error:", err);
      // Hide badge gracefully if fetch fails
      const badge = document.getElementById("scarcity-badge-old");
      if(badge) badge.style.display = 'none';
    }
  });
</script>
