---
const WHOP_LINK = "https://whop.com/escapenazis";
---

<section id="curriculum" class="w-full max-w-lg mx-auto bg-surface mt-10">
  
  <div class="border-b border-border py-4 px-4 flex items-center gap-4">
    <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    <h2 class="font-head font-semibold text-lg uppercase tracking-wider text-primary">Surviving Spiritual Stalking</h2>
  </div>

  <div class="bg-primary text-surface p-6 flex justify-between items-end border-b border-border">
    <div>
      <span class="text-xs font-body uppercase tracking-widest text-surface/70 mb-1 block">Full Curriculum Access</span>
      <h2 class="font-head text-4xl leading-none uppercase tracking-tight">Program<br/>Overview</h2>
    </div>
    <div class="text-right">
      <span class="text-sm line-through text-surface/50 font-body block">$197</span>
      <span class="font-head text-3xl leading-none">$47</span>
    </div>
  </div>

  <div class="p-4 bg-bg flex flex-col gap-6">
    <!-- Module 01 -->
    <div class="border border-border bg-surface shadow-hard">
      <div class="h-48 bg-primary relative overflow-hidden flex items-center justify-center">
        <!-- Abstract gradient block for placeholder image -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary to-gray-800 opacity-90"></div>
        <div class="w-4 h-full bg-surface/10 mx-auto opacity-50"></div>
        <div class="w-4 h-full bg-surface/10 mx-auto opacity-50"></div>
        
        <div class="absolute top-0 left-0 bg-primary border-b border-r border-border px-3 py-1">
          <span class="font-head text-xs tracking-widest text-surface uppercase">Module 01</span>
        </div>
      </div>
      <div class="p-4">
        <div class="inline-block border border-border px-2 py-0.5 text-[10px] font-body uppercase tracking-wider text-primary mb-3 bg-bg">
          PDF + Audio
        </div>
        <h3 class="font-head text-2xl text-primary uppercase leading-none mb-1">1. Lockdown</h3>
        <p class="font-body text-sm text-primary/80 italic mb-5 border-l-2 border-primary pl-2 uppercase tracking-wide">
          Energetic Severing
        </p>
        <a href={WHOP_LINK} class="w-full flex justify-center py-3 bg-primary text-surface font-head tracking-wider uppercase text-sm hover:bg-opacity-90 transition">
          Access Module
        </a>
      </div>
    </div>

    <!-- Module 02 -->
    <div class="border border-border bg-surface shadow-hard">
      <div class="h-48 bg-gray-400 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-300 to-gray-500 opacity-80 mix-blend-multiply"></div>
        <div class="absolute top-0 left-0 bg-primary border-b border-r border-border px-3 py-1">
          <span class="font-head text-xs tracking-widest text-surface uppercase">Module 02</span>
        </div>
      </div>
      <div class="p-4">
        <div class="inline-block border border-border px-2 py-0.5 text-[10px] font-body uppercase tracking-wider text-primary mb-3 bg-bg">
          PDF + Audio
        </div>
        <h3 class="font-head text-2xl text-primary uppercase leading-none mb-1">2. The Grey Rock</h3>
        <p class="font-body text-sm text-primary/80 italic mb-5 border-l-2 border-primary pl-2 uppercase tracking-wide">
          Becoming Uninteresting
        </p>
        <a href={WHOP_LINK} class="w-full flex justify-center py-3 bg-primary text-surface font-head tracking-wider uppercase text-sm hover:bg-opacity-90 transition">
          Access Module
        </a>
      </div>
    </div>

    <!-- Module 03 -->
    <div class="border border-border bg-surface shadow-hard">
      <div class="h-48 bg-primary relative overflow-hidden flex justify-center">
        <!-- Abstract architectural block placeholder -->
        <div class="w-12 h-full bg-surface shadow-lg mt-10"></div>
        <div class="absolute top-0 left-0 bg-primary border-b border-r border-border px-3 py-1">
          <span class="font-head text-xs tracking-widest text-surface uppercase">Module 03</span>
        </div>
      </div>
      <div class="p-4">
        <div class="inline-block border border-border px-2 py-0.5 text-[10px] font-body uppercase tracking-wider text-primary mb-3 bg-bg">
          PDF + Audio
        </div>
        <h3 class="font-head text-2xl text-primary uppercase leading-none mb-1">3. Architectural Defense</h3>
        <p class="font-body text-sm text-primary/80 italic mb-5 border-l-2 border-primary pl-2 uppercase tracking-wide">
          Securing Physical Space
        </p>
        <a href={WHOP_LINK} class="w-full flex justify-center py-3 bg-primary text-surface font-head tracking-wider uppercase text-sm hover:bg-opacity-90 transition">
          Access Module
        </a>
      </div>
    </div>
    
    <div class="mt-6 mb-12">
      <a href={WHOP_LINK} class="w-full flex justify-center py-4 bg-primary text-surface font-head tracking-widest text-lg uppercase shadow-hard hover:-translate-y-1 transition transform duration-200">
        Enroll Now For $47
      </a>
    </div>
  </div>
</section>
