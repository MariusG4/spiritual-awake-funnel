---
const WHOP_LINK = "https://whop.com/escapenazis";
---

<header class="bg-surface border-b border-border py-4 px-6 flex justify-between items-center">
  <div class="flex items-center gap-2 font-head font-semibold tracking-widest text-primary">
    <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </svg>
    SSS PROTOCOL
  </div>
  <button class="text-primary hover:text-accent transition">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>
</header>

<section class="bg-bg pt-12 pb-20 px-4 flex flex-col items-center text-center">
  <div class="border border-border px-3 py-1 text-xs font-head tracking-widest text-primary uppercase mb-8 inline-block bg-surface">
    Energetic Security Division
  </div>
  
  <h1 id="hero-headline" class="text-5xl md:text-6xl font-head font-semibold text-primary uppercase leading-none tracking-tight mb-6">
    Stop the Drain.
  </h1>
  
  <p class="text-lg md:text-xl text-primary max-w-lg mb-10 leading-relaxed">
    A clinical approach to ending spiritual harassment through tactical boundaries and energetic shielding.
  </p>
  
  <a href={WHOP_LINK} class="w-full max-w-sm btn-clinical mb-16 bg-primary text-surface hover:bg-opacity-90">
    Start the Protocol
  </a>

  <!-- Placeholder Image mimicking the abstract tech network -->
  <div class="w-full max-w-3xl h-64 md:h-96 bg-primary flex items-center justify-center overflow-hidden relative shadow-hard">
    <div class="absolute inset-0 opacity-40" style="background-image: radial-gradient(circle at center, #008080 0%, transparent 70%);"></div>
    <div class="relative z-10 text-surface/20 font-head text-4xl tracking-widest">SYSTEM SECURE</div>
  </div>
</section>

<!-- SYMPTOM CHECK SECTION -->
<section class="bg-bg pb-20 px-4 flex flex-col items-center">
  <div class="flex items-center w-full max-w-3xl mb-10">
    <div class="flex-grow border-t border-border"></div>
    <h2 class="px-4 text-xl font-head tracking-widest uppercase text-primary">Symptom Check</h2>
    <div class="flex-grow border-t border-border"></div>
  </div>

  <div class="w-full max-w-md flex flex-col gap-4 mb-20">
    <!-- Check 1 -->
    <div class="glass-panel flex gap-4 p-5 items-start">
      <div class="w-6 h-6 rounded bg-accent flex items-center justify-center flex-shrink-0 mt-1">
        <svg class="w-4 h-4 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="text-left">
        <h3 class="font-head text-lg text-primary uppercase tracking-wide mb-1">Sudden Energy Drops</h3>
        <p class="text-primary text-sm leading-relaxed">Unexplained fatigue occurring at consistent intervals without physical exertion.</p>
      </div>
    </div>
    
    <!-- Check 2 -->
    <div class="glass-panel flex gap-4 p-5 items-start">
      <div class="w-6 h-6 rounded bg-accent flex items-center justify-center flex-shrink-0 mt-1">
        <svg class="w-4 h-4 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="text-left">
        <h3 class="font-head text-lg text-primary uppercase tracking-wide mb-1">3AM Waking</h3>
        <p class="text-primary text-sm leading-relaxed">Systemic arousal during the "Thinning Hours" with immediate anxiety onset.</p>
      </div>
    </div>

    <!-- Check 3 -->
    <div class="glass-panel flex gap-4 p-5 items-start">
      <div class="w-6 h-6 rounded bg-accent flex items-center justify-center flex-shrink-0 mt-1">
        <svg class="w-4 h-4 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="text-left">
        <h3 class="font-head text-lg text-primary uppercase tracking-wide mb-1">Feeling Watched</h3>
        <p class="text-primary text-sm leading-relaxed">Persistent sensation of non-physical observation in private or secure spaces.</p>
      </div>
    </div>
  </div>

  <!-- THE STRATEGY QUOTE -->
  <div class="w-full max-w-2xl border border-border bg-surface p-8 md:p-12 text-center relative shadow-hard">
    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-surface px-2">
      <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
         <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
    </div>
    
    <h2 class="font-head text-3xl md:text-4xl text-primary uppercase leading-tight mt-6 mb-6 italic">
      "You don't need sage. You need strategy."
    </h2>
    <p class="text-primary text-base md:text-lg mb-10 leading-relaxed max-w-lg mx-auto">
      Move beyond mystical superstitions. Our protocol treats spiritual interference as a technical breach of your bio-energetic field. We use tactical isolation and structural reinforcement.
    </p>

    <!-- Phases Grid -->
    <div class="grid grid-cols-2 gap-y-6 gap-x-4 text-left border-l border-border pl-6 max-w-sm mx-auto mb-10">
      <div>
        <span class="text-xs text-primary/70 font-head tracking-widest uppercase">Phase 01</span>
        <h4 class="font-body font-bold text-primary">Isolation</h4>
      </div>
      <div>
        <span class="text-xs text-primary/70 font-head tracking-widest uppercase">Phase 02</span>
        <h4 class="font-body font-bold text-primary">Hardening</h4>
      </div>
      <div>
        <span class="text-xs text-primary/70 font-head tracking-widest uppercase">Phase 03</span>
        <h4 class="font-body font-bold text-primary">Counter-Ops</h4>
      </div>
      <div>
        <span class="text-xs text-primary/70 font-head tracking-widest uppercase">Phase 04</span>
        <h4 class="font-body font-bold text-primary">Recovery</h4>
      </div>
    </div>

    <a href={WHOP_LINK} class="w-full btn-clinical bg-primary text-surface hover:bg-opacity-90">
      Download System PDF
    </a>
  </div>
</section>

<script>
  // Simplified A/B testing logic to adapt to new structure if needed,
  // currently targeting hero-headline
  document.addEventListener('ab_variant_loaded', (e: any) => {
    const variant = e.detail?.variant;
    const headlineEl = document.getElementById('hero-headline');
    
    // Only apply if we want to test different clinical headlines
    if (headlineEl && variant === 'B') {
      headlineEl.innerHTML = `SEVER THE CONNECTION.`;
    }
  });
</script>
