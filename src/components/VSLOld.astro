---
const WHOP_LINK = "https://whop.com/escapenazis/surviving-spiritual-stalking";
---
<section class="vsl-section">
  <div class="container text-center">
    <h2 class="mb-4">⚠️ URGENT: Watch This Before They Find Out</h2>
    <p class="mb-8" style="color: var(--text-muted); max-width: 700px; margin: 0 auto 3rem;">
      If you've been in contact with drug dealers, black market people, or esotericists... and you're experiencing intrusive thoughts, night sweats, or feeling watched—<strong style="color: var(--accent);">this 2-minute video will change everything.</strong>
    </p>

    <div class="video-container glass-panel">
      <div class="iframe-wrapper">
        <iframe
          src="https://www.youtube-nocookie.com/embed/mqyGwE5VcUM?rel=0&modestbranding=1"
          title="Watch This Before They Find Out"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <div class="mt-8">
      <a href={WHOP_LINK} class="btn-primary">
        Yes, I'm Ready To Protect Myself
      </a>
    </div>
  </div>
</section>

<style>
  .vsl-section {
    padding: 6rem 0;
    background: rgba(var(--bg-dark-rgb), 0.3); /* Subtle backdrop */
  }

  h2 {
    font-size: 2.5rem;
  }

  .video-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem; /* Thin border/glass effect */
    border-radius: 20px;
  }

  .iframe-wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
  }

  .iframe-wrapper iframe {
    width: 100%;
    height: 100%;
    display: block;
    border: none;
  }



  @media (max-width: 768px) {
    .vsl-section { padding: 4rem 0; }
    h2 { font-size: 2rem; }
    .video-container { padding: 0.5rem; border-radius: 12px; }
    .vsl-placeholder { border-radius: 8px; }
  }
</style>
