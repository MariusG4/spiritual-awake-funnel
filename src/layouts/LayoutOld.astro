---
import '../styles/global-old.css';

import SEO from '../components/SEO.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
  author?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  faq?: any[];
  /** Pass true only on the page that actually embeds the shielding video. */
  videoSchema?: boolean;
  /** Pass true only on the homepage to emit the Product schema. */
  productSchema?: boolean;
}

const { title, description = "Stop Unwanted Spiritual Intrusion Before It Escalates", ...seoProps } = Astro.props;

// Read analytics IDs from environment variables if present
const GTM_ID = import.meta.env.GTM_ID || '';
const GA4_ID = import.meta.env.GA4_ID || 'G-XXXXXXXXXX';
const META_PIXEL_ID = import.meta.env.META_PIXEL_ID || 'XXXXXXXXXX';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<SEO title={title} description={description} {...seoProps} />
		<slot name="head" />

		<!-- Cookiebot Consent Management (must be first, before any other scripts) -->
		<script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="4679d381-4739-4678-bbbf-9e964f98cc77" data-blockingmode="auto" type="text/javascript" async></script>

		<!-- Google Tag Manager (Cookiebot controlled) -->
		{GTM_ID && (
			<script is:inline define:vars={{ GTM_ID }}>
				var s = document.createElement('script');
				s.type = 'text/plain';
				s.setAttribute('data-cookieconsent', 'statistics');
				s.text = '(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);})(window,document,"script","dataLayer","' + GTM_ID + '");';
				document.head.appendChild(s);
			</script>
		)}
		<!-- End Google Tag Manager -->

		<!-- Google Analytics (gtag.js) -->
		{GA4_ID !== 'G-XXXXXXXXXX' && (
			<>
				<script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
				<script type="text/partytown" define:vars={{ GA4_ID }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', GA4_ID);
				</script>
			</>
		)}

		<!-- Meta Pixel Code -->
		{META_PIXEL_ID !== 'XXXXXXXXXX' && (
			<script type="text/partytown" define:vars={{ META_PIXEL_ID }}>
				!function(f,b,e,v,n,t,s)
				{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
				n.callMethod.apply(n,arguments):n.queue.push(arguments)};
				if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
				n.queue=[];t=b.createElement(e);t.async=!0;
				t.src=v;s=b.getElementsByTagName(e)[0];
				s.parentNode.insertBefore(t,s)}(window, document,'script',
				'https://connect.facebook.net/en_US/fbevents.js');
				fbq('init', META_PIXEL_ID);
				fbq('track', 'PageView');
			</script>
		)}

		<!-- Lottie Player JS -->
		<script async defer src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
		
		<!-- Cloudinary CDN — preconnect so hero images load without DNS delay -->
		<link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
		<link rel="dns-prefetch" href="https://res.cloudinary.com" />

		<!-- Cloudflare Turnstile -->
		<link rel="preconnect" href="https://challenges.cloudflare.com">
		<script
			is:inline
			src="https://challenges.cloudflare.com/turnstile/v0/api.js"
			async
			defer
		></script>
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		{GTM_ID && (
			<div data-cookieconsent="statistics" style="display:none">
				<noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
				height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
			</div>
		)}
		<!-- End Google Tag Manager (noscript) -->
		
		<!-- Sticky Top Bar (Urgency) -->
		<div class="sticky-bar">
			<p>🔒 <strong id="sticky-scarcity-text">Limited Spots Available</strong> — Secure your access to the exclusive group today.</p>
		</div>
		<script>
			const initStickyScarcity = async () => {
				try {
					const { supabase } = await import("../lib/supabase");
					const { data, error } = await supabase
						.from("whop_products")
						.select("scarcity")
						.eq('whop_product_id', 'prod_nS8yhc2paxstR')
						.single();
					if (error) throw error;
					const badge = document.getElementById("sticky-scarcity-text");
					if (badge) badge.innerText = `Only ${data.scarcity} Spots Left!`;
				} catch (err) {
					console.error("Sticky Scarcity Error:", err);
				}
			};
			initStickyScarcity();
		</script>

		<slot />

		<script>
			// Basic A/B Testing router
			// Check if user has a variant assigned, if not assign 50/50
			document.addEventListener('DOMContentLoaded', () => {
				let variant = localStorage.getItem('ab_variant');
				if (!variant) {
					variant = Math.random() < 0.5 ? 'A' : 'B';
					localStorage.setItem('ab_variant', variant);
				}
				
				if (variant === 'B') {
					document.documentElement.setAttribute('data-theme', 'gold');
				}

				// Push to dataLayer for GA4 custom dimension
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({
					'event': 'ab_variant_assignment',
					'ab_variant': variant
				});

				// Dispatch event so components can react
				document.dispatchEvent(new CustomEvent('ab_variant_loaded', { detail: { variant } }));
			});

			// CTA Click Tracking
			document.querySelectorAll('.btn-primary').forEach(button => {
				button.addEventListener('click', () => {
					(window as any).dataLayer = (window as any).dataLayer || [];
					(window as any).dataLayer.push({
						'event': 'cta_click',
						'button_text': button.textContent?.trim()
					});

					if (typeof (window as any).fbq === 'function') {
						(window as any).fbq('track', 'InitiateCheckout');
					}
				});
			});
		</script>

		<!-- Site-wide Footer -->
		<footer class="site-footer">

			<!-- Newsletter band — full-width, sits above the nav columns -->
			<div class="footer-newsletter-band">
				<div class="footer-newsletter-inner">
					<NewsletterSignup variant="inline" />
				</div>
			</div>

			<div class="footer-inner">

				<!-- Brand column — mirrors Organization JSON-LD name + description -->
				<div class="footer-brand">
					<p class="footer-logo">🛡️ Spiritual Shield System</p>
					<p class="footer-tagline">
						A trusted resource for spiritual discernment, biblical understanding,
						 and practical guidance for facing spiritual oppression,fear, 
						 and deception — offering clear, grounded teaching without esoteric language or mystical systems.
					</p>
				</div>

				<!-- Primary navigation + E-E-A-T contact signal -->
				<nav class="footer-nav" aria-label="Site navigation links">
					<p class="footer-nav-label">Explore</p>
					<ul class="footer-nav-list">
						<li>
							<a href="/" title="Spiritual Shield System — Home">Home</a>
						</li>
						<li>
							<a href="/blog" title="Spiritual protection articles and psychic defense guides">Blog</a>
						</li>
						<li>
							<a
								href="mailto:support@spiritualshieldsystem.com"
								title="Contact Spiritual Shield System support"
							>
								Contact Support
							</a>
						</li>
						<li>
							<a
								href="https://whop.com/escapenazis/surviving-spiritual-stalking"
								target="_blank"
								rel="noopener noreferrer"
								title="Join the private spiritual protection and energy management community"
							>
								Join the Community ↗
							</a>
						</li>
					</ul>
				</nav>

				<!-- Popular Resources — cornerstone internal links for crawl depth + link equity -->
				<nav class="footer-nav" aria-label="Popular resources">
					<p class="footer-nav-label">Popular Resources</p>
					<ul class="footer-nav-list">
						<li>
							<a
								href="/blog/10-warning-signs-spiritual-stalking"
								title="Identify the 10 warning signs of spiritual stalking and psychic intrusion"
							>
								10 Warning Signs of Spiritual Stalking
							</a>
						</li>
						<li>
							<a
								href="/blog/understanding-spiritual-shielding-basics"
								title="Learn the basics of spiritual shielding and metaphysical protection"
							>
								Spiritual Shielding Basics
							</a>
						</li>
						<li>
							<a
								href="/blog/spiritual-warfare-signs"
								title="Discover hidden signs of spiritual warfare and energetic attack"
							>
								Hidden Signs of Spiritual Warfare
							</a>
						</li>
						<li>
							<a
								href="/blog/ancient-war-spiritual-harassment"
								title="Explore the ancient history of spiritual harassment and psychic self-defense"
							>
								The Ancient War: Spiritual Harassment
							</a>
						</li>
					</ul>
				</nav>

			</div>

			<div class="footer-bottom">
				<p class="footer-copy">
					© <span id="footer-year"></span> Shield Your Energy. All rights reserved.
				</p>
			</div>
		</footer>
		<script is:inline>
			document.getElementById('footer-year').textContent = new Date().getFullYear();
		</script>
	</body>
</html>

<style>
	.sticky-bar {
		position: sticky;
		top: 0;
		z-index: 50;
		background: linear-gradient(90deg, var(--secondary), var(--primary));
		color: white;
		text-align: center;
		padding: 0.75rem 1rem;
		font-size: 0.9rem;
		font-weight: 500;
		box-shadow: 0 4px 6px rgba(0,0,0,0.1);
	}
	.sticky-bar p {
		margin: 0;
	}
	
	@media (max-width: 600px) {
		.sticky-bar {
			font-size: 0.8rem;
		}
	}

	/* ─── Site Footer ─────────────────────────────────────────────────────── */
	.site-footer {
		position: relative;
		background: var(--glass-bg, rgba(255, 255, 255, 0.04));
		border-top: 1px solid var(--glass-border, rgba(255, 255, 255, 0.08));
		margin-top: 4rem;
	}
	/* Gradient accent line — mirrors the sticky-bar colorway */
	.site-footer::before {
		content: '';
		display: block;
		height: 3px;
		background: linear-gradient(90deg, var(--secondary), var(--primary));
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 1.5rem 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		text-align: center;
	}
	/* Tablet: brand spans full width; two nav columns side-by-side */
	@media (min-width: 640px) {
		.footer-inner {
			grid-template-columns: 1fr 1fr;
			text-align: left;
		}
		.footer-brand {
			grid-column: 1 / -1;
		}
	}
	/* Desktop: true three-column layout — brand wider, two compact nav columns */
	@media (min-width: 900px) {
		.footer-inner {
			grid-template-columns: 2fr 1fr 1.5fr;
		}
		.footer-brand {
			grid-column: auto;
		}
	}

	/* Brand column */
	.footer-logo {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-main);
		margin: 0 0 0.75rem;
		letter-spacing: 0.01em;
	}
	.footer-tagline {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
		max-width: 340px;
	}
	@media (max-width: 639px) {
		.footer-tagline { margin-inline: auto; }
	}

	/* Nav column */
	.footer-nav-label {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 0.85rem;
	}
	.footer-nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.footer-nav-list a {
		font-size: 0.95rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-nav-list a:hover {
		color: var(--primary);
	}

	/* Bottom bar */
	.footer-bottom {
		border-top: 1px solid var(--glass-border, rgba(255, 255, 255, 0.08));
		padding: 1rem 1.5rem;
		text-align: center;
	}
	.footer-copy {
		margin: 0;
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	/* ── Footer newsletter band ────────────────────────────────────────────── */
	.footer-newsletter-band {
		border-bottom: 1px solid var(--glass-border, rgba(255, 255, 255, 0.08));
		/* Subtle primary tint to visually separate the band from the nav below */
		background: rgba(var(--primary-rgb, 139, 92, 246), 0.04);
	}
	.footer-newsletter-inner {
		max-width: 1100px;
		margin: 0 auto;
		/* Match the footer-inner vertical rhythm: 2.5rem top, 2rem bottom */
		padding: 2.5rem 1.5rem 2rem;
	}
</style>
