---
import '../styles/global-old.css';

import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
  author?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  faq?: any[];
  /** Pass true only on the page that actually embeds the shielding video. */
  videoSchema?: boolean;
}

const { title, description = "Stop Unwanted Spiritual Intrusion Before It Escalates", ...seoProps } = Astro.props;

// Read analytics IDs from environment variables if present
const GTM_ID = import.meta.env.GTM_ID || '';
const GA4_ID = import.meta.env.GA4_ID || 'G-XXXXXXXXXX';
const META_PIXEL_ID = import.meta.env.META_PIXEL_ID || 'XXXXXXXXXX';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<SEO title={title} description={description} {...seoProps} />
		<slot name="head" />

		<!-- Cookiebot Consent Management (must be first, before any other scripts) -->
		<script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="4679d381-4739-4678-bbbf-9e964f98cc77" data-blockingmode="auto" type="text/javascript" async></script>

		<!-- Google Tag Manager (Cookiebot controlled) -->
		{GTM_ID && (
			<script is:inline define:vars={{ GTM_ID }}>
				var s = document.createElement('script');
				s.type = 'text/plain';
				s.setAttribute('data-cookieconsent', 'statistics');
				s.text = '(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);})(window,document,"script","dataLayer","' + GTM_ID + '");';
				document.head.appendChild(s);
			</script>
		)}
		<!-- End Google Tag Manager -->

		<!-- Google Analytics (gtag.js) -->
		{GA4_ID !== 'G-XXXXXXXXXX' && (
			<>
				<script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
				<script type="text/partytown" define:vars={{ GA4_ID }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', GA4_ID);
				</script>
			</>
		)}

		<!-- Meta Pixel Code -->
		{META_PIXEL_ID !== 'XXXXXXXXXX' && (
			<script type="text/partytown" define:vars={{ META_PIXEL_ID }}>
				!function(f,b,e,v,n,t,s)
				{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
				n.callMethod.apply(n,arguments):n.queue.push(arguments)};
				if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
				n.queue=[];t=b.createElement(e);t.async=!0;
				t.src=v;s=b.getElementsByTagName(e)[0];
				s.parentNode.insertBefore(t,s)}(window, document,'script',
				'https://connect.facebook.net/en_US/fbevents.js');
				fbq('init', META_PIXEL_ID);
				fbq('track', 'PageView');
			</script>
		)}

		<!-- Lottie Player JS -->
		<script async defer src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
		
		<!-- Cloudflare Turnstile -->
		<link rel="preconnect" href="https://challenges.cloudflare.com">
		<script
			is:inline
			src="https://challenges.cloudflare.com/turnstile/v0/api.js"
			async
			defer
		></script>
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		{GTM_ID && (
			<div data-cookieconsent="statistics" style="display:none">
				<noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
				height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
			</div>
		)}
		<!-- End Google Tag Manager (noscript) -->
		
		<!-- Sticky Top Bar (Urgency) -->
		<div class="sticky-bar">
			<p>🔒 <strong id="sticky-scarcity-text">Limited Spots Available</strong> — Secure your access to the exclusive group today.</p>
		</div>
		<script>
			const initStickyScarcity = async () => {
				try {
					const { supabase } = await import("../lib/supabase");
					const { data, error } = await supabase
						.from("whop_products")
						.select("scarcity")
						.eq('whop_product_id', 'prod_nS8yhc2paxstR')
						.single();
					if (error) throw error;
					const badge = document.getElementById("sticky-scarcity-text");
					if (badge) badge.innerText = `Only ${data.scarcity} Spots Left!`;
				} catch (err) {
					console.error("Sticky Scarcity Error:", err);
				}
			};
			initStickyScarcity();
		</script>

		<slot />

		<script>
			// Basic A/B Testing router
			// Check if user has a variant assigned, if not assign 50/50
			document.addEventListener('DOMContentLoaded', () => {
				let variant = localStorage.getItem('ab_variant');
				if (!variant) {
					variant = Math.random() < 0.5 ? 'A' : 'B';
					localStorage.setItem('ab_variant', variant);
				}
				
				if (variant === 'B') {
					document.documentElement.setAttribute('data-theme', 'gold');
				}

				// Push to dataLayer for GA4 custom dimension
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({
					'event': 'ab_variant_assignment',
					'ab_variant': variant
				});

				// Dispatch event so components can react
				document.dispatchEvent(new CustomEvent('ab_variant_loaded', { detail: { variant } }));
			});

			// CTA Click Tracking
			document.querySelectorAll('.btn-primary').forEach(button => {
				button.addEventListener('click', () => {
					(window as any).dataLayer = (window as any).dataLayer || [];
					(window as any).dataLayer.push({
						'event': 'cta_click',
						'button_text': button.textContent?.trim()
					});

					if (typeof (window as any).fbq === 'function') {
						(window as any).fbq('track', 'InitiateCheckout');
					}
				});
			});
		</script>
	</body>
</html>

<style>
	.sticky-bar {
		position: sticky;
		top: 0;
		z-index: 50;
		background: linear-gradient(90deg, var(--secondary), var(--primary));
		color: white;
		text-align: center;
		padding: 0.75rem 1rem;
		font-size: 0.9rem;
		font-weight: 500;
		box-shadow: 0 4px 6px rgba(0,0,0,0.1);
	}
	.sticky-bar p {
		margin: 0;
	}
	
	@media (max-width: 600px) {
		.sticky-bar {
			font-size: 0.8rem;
		}
	}
</style>
